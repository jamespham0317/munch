{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // @munch/core ships as source (no build step) and is consumed by bundlers
    // (Next.js, Metro) and Vitest. "Bundler" resolution lets those tools — and
    // this package's own typecheck — use extensionless relative imports.
    "module": "ESNext",
    "moduleResolution": "Bundler"
  },
  "include": ["src"]
}
