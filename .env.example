# Public, client-safe configuration ONLY.
# Never put the Supabase service-role key or any provider API key in this file
# or in any app bundle — server-only secrets live in Supabase Edge Function env.
# (See CLAUDE.md §3 and docs/06-coding-standards.md §12.)

# Supabase — the anon key is public and safe to ship.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Web (Next.js) — used in Prompt 5.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Mobile (Expo) — used in Prompt 6.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
