{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Next.js bundles the app and consumes the workspace packages' raw TS source,
    // so override the base's NodeNext settings: "Bundler" resolution + DOM libs +
    // the JSX-preserve / next-plugin wiring Next expects. Base strictness
    // (noUncheckedIndexedAccess, exactOptionalPropertyTypes, …) is inherited.
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "allowJs": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
