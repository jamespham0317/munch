{
  "name": "@munch/web",
  "version": "0.0.0",
  "private": true,
  "description": "Munch web app (Next.js App Router). Consumes @munch/core + @munch/api-client; Phase 1 guest create/join + live-presence room lobby.",
  "scripts": {
    "generate-theme": "tsx scripts/generate-theme.ts",
    "generate-theme:check": "tsx scripts/generate-theme.ts --check",
    "dev": "pnpm generate-theme && next dev",
    "build": "pnpm generate-theme && next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "pnpm generate-theme:check"
  },
  "dependencies": {
    "@munch/api-client": "workspace:*",
    "@munch/core": "workspace:*",
    "@munch/ui": "workspace:*",
    "@supabase/supabase-js": "^2",
    "@tanstack/react-query": "^5.100.14",
    "canvas-confetti": "^1.9.4",
    "lucide-react": "^1.17.0",
    "maplibre-gl": "^5.9.0",
    "next": "^16.2.6",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2"
  }
}
