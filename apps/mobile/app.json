{
  "expo": {
    "name": "Munch",
    "slug": "munch",
    "scheme": "munch",
    "version": "0.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "associatedDomains": ["applinks:munch.app"]
    },
    "android": {
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": ["BROWSABLE", "DEFAULT"],
          "data": [
            {
              "scheme": "https",
              "host": "munch.app",
              "pathPrefix": "/room/join"
            }
          ]
        }
      ]
    },
    "plugins": ["expo-router", "expo-status-bar", "expo-web-browser"]
  }
}
