# Public, client-safe config ONLY (CLAUDE.md §3). The anon key is safe to ship;
# never put the Supabase service-role key or any provider key here or in the bundle.
#
# Expo loads .env from this app directory — copy to apps/mobile/.env and fill in.
# The URL must be reachable from the device: 127.0.0.1 (iOS simulator),
# 10.0.2.2 (Android emulator), or your host LAN IP (physical device).
# The anon key is printed by `supabase start`.
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=
