# React Native / Metro do not fully support pnpm's default isolated, symlinked
# node_modules layout, so the Expo app (apps/mobile) fails to resolve native deps
# under it. `node-linker=hoisted` gives a flat, npm-style layout that Metro and
# RN's native module resolution expect. This is Expo's documented fix for pnpm
# monorepos and changes install layout only — no package code depends on it.
node-linker=hoisted
